# ─────────────────────────────────────────────────────────────
#  Fare Watcher – Environment Variables
#  Fill in each value below. Do NOT share this file with anyone.
# ─────────────────────────────────────────────────────────────

# Step 1 ► Go to https://rapidapi.com → sign up → search "Skyscanner"
#           Subscribe to the free tier → copy your key here:
RAPIDAPI_KEY=

# Step 2 ► Open Telegram → search for @BotFather → send /newbot
#           Follow the prompts → copy the token it gives you here:
TELEGRAM_BOT_TOKEN=

# Step 3 ► In Telegram, search for @userinfobot → send /start
#           It will reply with your Chat ID → paste it here:
TELEGRAM_CHAT_ID=

# Step 4 ► Your departure airport code (e.g. JFK, LHR, LAX, SYD)
#           See codes at https://www.iata.org/en/publications/directories/code-search/
ORIGIN_AIRPORT=TLV
